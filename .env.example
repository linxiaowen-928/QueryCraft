# ============================================
# QueryCraft Docker 环境变量配置
# ============================================

# --------------------------------------------
# API 配置
# --------------------------------------------
API_PORT=8080

# LLM 配置
LLM_PROVIDER=openai  # openai | deepseek | local
LLM_MODEL=gpt-4
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=  # 可选，自定义 API 地址

# 日志配置
LOG_LEVEL=info  # debug | info | warning | error

# 数据库配置（可选）
DATABASE_URL=

# --------------------------------------------
# MySQL 配置（可选）
# --------------------------------------------
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=test
MYSQL_USER=querycraft
MYSQL_PASSWORD=querycraft

# --------------------------------------------
# PostgreSQL 配置（可选）
# --------------------------------------------
POSTGRES_PORT=5432
POSTGRES_USER=querycraft
POSTGRES_PASSWORD=querycraft
POSTGRES_DB=test
