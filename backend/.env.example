# QueryCraft 配置文件
# 复制此文件为 .env 并填入实际值

# LLM 配置 (必填)
# 支持: OpenAI, DeepSeek, ZhipuAI 等
# 获取 API Key: https://open.bigmodel.cn/ (智谱AI) 或 https://platform.openai.com/ (OpenAI)
LLM_API_KEY=your-api-key-here

# 可选配置
LLM_PROVIDER=zhipuai
LLM_MODEL=glm-4-flash

# 服务器配置
HOST=0.0.0.0
PORT=8080
DEBUG=false

# 安全配置
SECRET_KEY=change-me-in-production